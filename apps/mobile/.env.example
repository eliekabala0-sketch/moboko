# Même projet Supabase que le web — clé anon uniquement (jamais service_role).
EXPO_PUBLIC_SUPABASE_URL=https://votre-projet.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=votre_cle_anon

# Backend Next.js (Railway) — sans slash final. Défaut identique dans app.config.ts si variable absente.
EXPO_PUBLIC_API_BASE_URL=https://moboko-production.up.railway.app
# Même origine que le site (OAuth / liens e-mail) ; défaut = MOBOKO_SITE_URL_PRODUCTION dans @moboko/shared.
EXPO_PUBLIC_SITE_URL=https://moboko-production.up.railway.app
