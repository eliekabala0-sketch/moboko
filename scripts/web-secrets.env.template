# Renommer en web-secrets.env et placer dans :
#   %USERPROFILE%\.moboko\web-secrets.env   (Windows)
#   $HOME/.moboko/web-secrets.env           (Unix)
# ou : .secrets/web.env à la racine du dépôt (ignoré par git)
# ou : variable MOBOKO_WEB_SECRETS_FILE = chemin absolu vers un fichier .env
# CI : définir SUPABASE_SERVICE_ROLE_KEY et OPENAI_API_KEY avant npm ci (postinstall → bootstrap).
SUPABASE_SERVICE_ROLE_KEY=
OPENAI_API_KEY=
